<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Configurações Globais do Bot - Quasar</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen font-sans">
  <div class="max-w-2xl mx-auto px-4 py-16">
    <div class="mb-8 flex items-center justify-between">
      <h1 class="text-3xl font-extrabold text-blue-500">Desenvolvedor Quasar</h1>
      <a href="/dashboard" class="text-xs text-slate-400 hover:underline">Voltar ao painel</a>
    </div>

    <form action="/admin/update" method="POST" class="bg-slate-900 border border-slate-800 rounded-2xl p-6 space-y-6">
      <div>
        <label class="block text-xs font-semibold uppercase text-slate-400 tracking-widest mb-2">Status do Bot (Presença)</label>
        <select name="status" class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-slate-100 focus:ring-2 focus:ring-blue-500 outline-none">
          <option value="online" <%= settings.status === 'online' ? 'selected' : '' %>>Ativo (Online)</option>
          <option value="idle" <%= settings.status === 'idle' ? 'selected' : '' %>>Ausente (Idle)</option>
          <option value="dnd" <%= settings.status === 'dnd' ? 'selected' : '' %>>Não Perturbe (DND)</option>
        </select>
      </div>

      <div class="grid grid-cols-4 gap-4">
        <div class="col-span-1">
          <label class="block text-xs font-semibold uppercase text-slate-400 tracking-widest mb-2">Emoji</label>
          <input type="text" name="activityEmoji" value="<%= settings.activityEmoji %>" placeholder="💎" class="w-full text-center px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-slate-100 outline-none">
        </div>
        <div class="col-span-3">
          <label class="block text-xs font-semibold uppercase text-slate-400 tracking-widest mb-2">Status Customizado (Mensagem)</label>
          <input type="text" name="activityText" value="<%= settings.activityText %>" placeholder="Toque músicas de alta definição" class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-slate-100 outline-none">
        </div>
      </div>

      <button type="submit" class="w-full py-3 bg-amber-500 hover:bg-amber-600 font-bold rounded-lg transition-colors text-slate-950">Salvar Mudanças Dinâmicas</button>
    </form>
  </div>
</body>
</html>
