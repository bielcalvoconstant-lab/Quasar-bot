<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Krypton | <%= mode === 'login' ? 'Login' : (mode === 'register' ? 'Cadastro' : 'Recuperação') %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#0b0f19] text-slate-100 min-h-screen flex items-center justify-center p-6">
  <div class="max-w-md w-full bg-slate-900/60 p-8 rounded-2xl border border-slate-800 shadow-xl space-y-6">
    
    <div class="text-center">
      <h1 class="text-2xl font-black text-violet-400">
        <%= mode === 'login' ? 'Acessar o Painel' : (mode === 'register' ? 'Criar Nova Conta' : (mode === 'forgot' ? 'Recuperar Senha' : 'Definir Nova Senha')) %>
      </h1>
      <p class="text-xs text-slate-400 mt-2">
        <%= mode === 'login' ? 'Insira seus dados para autenticar' : (mode === 'register' ? 'Preencha o formulário para se registrar' : 'Digite o seu e-mail para receber um link de recuperação') %>
      </p>
    </div>

    <% if (error) { %>
      <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-3 rounded-xl text-xs text-center">
        <%= error %>
      </div>
    <% } %>

    <!-- MODO LOGIN -->
    <% if (mode === 'login') { %>
      <form action="/login" method="POST" class="space-y-4">
        <div>
          <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Endereço de E-mail</label>
          <input type="email" name="email" placeholder="exemplo@dominio.com" class="w-full bg-slate-950 p-3.5 rounded-xl border border-slate-800 focus:border-violet-500 text-xs text-slate-200 outline-none transition" required />
        </div>
        <div>
          <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Sua Senha</label>
          <input type="password" name="password" placeholder="••••••••" class="w-full bg-slate-950 p-3.5 rounded-xl border border-slate-800 focus:border-violet-500 text-xs text-slate-200 outline-none transition" required />
        </div>
        
        <button type="submit" class="w-full bg-violet-600 hover:bg-violet-500 text-white font-bold py-3.5 rounded-xl transition text-xs shadow-lg shadow-violet-600/20">
          Fazer Login (Sem Código OTP)
        </button>
      </form>

      <!-- BOTÕES DE LOGIN INTEGRADOS DO GOOGLE E DISCORD (1 CLIQUE - SEM OTP) -->
      <div class="space-y-2 pt-4 border-t border-slate-800">
        <a href="/auth/google" class="w-full bg-[#EA4335] hover:bg-[#d63022] text-white font-bold py-3 rounded-xl transition text-xs flex items-center justify-center gap-2.5 shadow-lg shadow-red-500/10">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12.24 10.285V14.4h6.887c-.648 2.41-2.519 4.113-5.111 4.113-3.418 0-6.192-2.774-6.192-6.192s2.774-6.192 6.192-6.192c1.472 0 2.825.518 3.901 1.381l3.064-3.064C18.91 2.43 15.76 1.3 12.016 1.3c-5.91 0-10.704 4.793-10.704 10.704s4.793 10.704 10.704 10.704c5.91 0 10.36-4.113 10.36-10.704 0-.648-.07-1.296-.18-1.921H12.24z"/>
          </svg>
          Entrar com o Google
        </a>
        <a href="/auth/login" class="w-full bg-[#5865F2] hover:bg-[#4752C4] text-white font-bold py-3 rounded-xl transition text-xs flex items-center justify-center gap-2.5 shadow-lg shadow-indigo-500/10">
          <svg class="w-4 h-4" viewBox="0 0 127.14 96.36" fill="currentColor">
            <path d="M107.7,8.07A105.15,105.15,0,0,0,77.26,0a77.19,77.19,0,0,0-3.3,6.83A96.67,96.67,0,0,0,53.22,6.83,77.19,77.19,0,0,0,49.88,0,105.15,105.15,0,0,0,19.44,8.07C3.66,31.58-1.86,54.65,1,77.53A105.73,105.73,0,0,0,32,96.36a77.7,77.7,0,0,0,6.63-10.85,68.43,68.43,0,0,1-10.45-5c.87-.64,1.71-1.32,2.51-2a75.4,75.4,0,0,0,72.84,0c.8.7,1.64,1.38,2.51,2a68.43,68.43,0,0,1-10.45,5,77.7,77.7,0,0,0,6.63,10.85,105.73,105.73,0,0,0,31-18.83C129.1,50.15,123.11,27.32,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53S36.18,40.36,42.45,40.36,53.83,46,53.83,53,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.24,60,73.24,53S78.41,40.36,84.69,40.36,96.07,46,96.07,53,91,65.69,84.69,65.69Z"/>
          </svg>
          Entrar com o Discord
        </a>
      </div>

      <div class="flex justify-between items-center text-xs text-violet-400 pt-4 mt-2">
        <a href="/register" class="hover:underline">Criar uma conta</a>
        <a href="/forgot-password" class="hover:underline">Esqueci a minha senha</a>
      </div>

    <!-- MODO REGISTRO (ENVIARÁ OTP) -->
    <% } else if (mode === 'register') { %>
      <form action="/register" method="POST" class="space-y-4">
        <div>
          <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Endereço de E-mail</label>
          <input type="email" name="email" placeholder="exemplo@dominio.com" class="w-full bg-slate-950 p-3.5 rounded-xl border border-slate-800 focus:border-violet-500 text-xs text-slate-200 outline-none transition" required />
        </div>
        <div>
          <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Crie uma Senha Forte</label>
          <input type="password" name="password" placeholder="••••••••" class="w-full bg-slate-950 p-3.5 rounded-xl border border-slate-800 focus:border-violet-500 text-xs text-slate-200 outline-none transition" required />
        </div>
        <button type="submit" class="w-full bg-violet-600 hover:bg-violet-500 text-white font-bold py-3.5 rounded-xl transition text-xs">
          Registrar e Receber Código por E-mail
        </button>
      </form>

      <div class="space-y-2 pt-4 border-t border-slate-800">
        <a href="/auth/google" class="w-full bg-[#EA4335] hover:bg-[#d63022] text-white font-bold py-3 rounded-xl transition text-xs flex items-center justify-center gap-2.5">
          Cadastrar com o Google
        </a>
        <a href="/auth/login" class="w-full bg-[#5865F2] hover:bg-[#4752C4] text-white font-bold py-3 rounded-xl transition text-xs flex items-center justify-center gap-2.5">
          Cadastrar com o Discord
        </a>
      </div>

      <div class="text-center text-xs text-violet-400 pt-4 mt-2">
        <a href="/login" class="hover:underline">Já tem uma conta? Faça Login</a>
      </div>

    <!-- MODO ESQUECI A SENHA -->
    <% } else if (mode === 'forgot') { %>
      <form action="/forgot-password" method="POST" class="space-y-4">
        <div>
          <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Digite seu e-mail cadastrado</label>
          <input type="email" name="email" placeholder="exemplo@dominio.com" class="w-full bg-slate-950 p-3.5 rounded-xl border border-slate-800 focus:border-violet-500 text-xs text-slate-200 outline-none transition" required />
        </div>
        <button type="submit" class="w-full bg-violet-600 hover:bg-violet-500 text-white font-bold py-3.5 rounded-xl transition text-xs">
          Enviar Código de Recuperação
        </button>
      </form>
      <div class="text-center text-xs text-violet-400 pt-4 border-t border-slate-800">
        <a href="/login" class="hover:underline">Voltar para o Login</a>
      </div>

    <!-- MODO DEFINIR NOVA SENHA -->
    <% } else if (mode === 'reset') { %>
      <form action="/reset-password" method="POST" class="space-y-4">
        <input type="hidden" name="email" value="<%= email %>" />
        <div>
          <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Código de 6 dígitos recebido por e-mail</label>
          <input type="text" name="code" placeholder="123456" maxlength="6" class="w-full bg-slate-950 p-3.5 rounded-xl border border-slate-800 focus:border-violet-500 text-xs text-center font-bold tracking-widest outline-none transition" required />
        </div>
        <div>
          <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Sua Nova Senha</label>
          <input type="password" name="password" placeholder="••••••••" class="w-full bg-slate-950 p-3.5 rounded-xl border border-slate-800 focus:border-violet-500 text-xs text-slate-200 outline-none transition" required />
        </div>
        <button type="submit" class="w-full bg-violet-600 hover:bg-violet-500 text-white font-bold py-3.5 rounded-xl transition text-xs">
          Redefinir Senha de Acesso
        </button>
      </form>
    <% } %>

  </div>
</body>
</html>
