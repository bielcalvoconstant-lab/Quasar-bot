<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Acesso - Portal Quasar</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-slate-100 flex items-center justify-center min-h-screen font-sans">
  <div class="w-full max-w-md bg-slate-900 border border-slate-800 p-8 rounded-2xl shadow-xl">
    <div class="text-center mb-6">
      <h1 class="text-3xl font-extrabold tracking-tight text-blue-500">Quasar</h1>
      <p class="text-slate-400 text-sm mt-1">Sua plataforma centralizada de música e moderação</p>
    </div>

    <!-- Mensagens de Alerta de Erro em Tempo Real -->
    <% if (error) { %>
      <div class="bg-red-500/10 border border-red-500 text-red-400 p-3 rounded-lg text-sm mb-4">
        <%= error %>
      </div>
    <% } %>

    <!-- Mensagens de Alerta de Sucesso -->
    <% if (success) { %>
      <div class="bg-green-500/10 border border-green-500 text-green-400 p-3 rounded-lg text-sm mb-4">
        <%= success %>
      </div>
    <% } %>

    <!-- Aba de Login Local -->
    <div id="login-tab">
      <form action="/auth/login" method="POST" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">E-mail</label>
          <input type="email" name="email" required class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-100 outline-none transition">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Senha</label>
          <input type="password" name="password" required class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-100 outline-none transition">
        </div>
        <button type="submit" class="w-full py-2.5 bg-blue-600 hover:bg-blue-700 font-bold rounded-lg transition-colors">Entrar</button>
      </form>
      <div class="mt-4 text-center">
        <button onclick="toggleTab('register')" class="text-xs text-blue-400 hover:underline">Ainda não tem conta? Cadastre-se</button>
      </div>
    </div>

    <!-- Aba de Cadastro Local (Dispara OTP via Brevo) -->
    <div id="register-tab" class="hidden">
      <form action="/auth/register" method="POST" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">E-mail Comercial</label>
          <input type="email" name="email" required class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-100 outline-none transition">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Senha Segura</label>
          <input type="password" name="password" required class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-slate-100 outline-none transition">
        </div>
        <button type="submit" class="w-full py-2.5 bg-blue-600 hover:bg-blue-700 font-bold rounded-lg transition-colors">Cadastrar & Receber Código</button>
      </form>
      <div class="mt-4 text-center">
        <button onclick="toggleTab('login')" class="text-xs text-blue-400 hover:underline">Já possui uma conta? Acesse</button>
      </div>
    </div>

    <!-- Divisor Visual -->
    <div class="mt-6 flex items-center justify-between">
      <hr class="w-full border-slate-800">
      <span class="text-xs text-slate-500 px-3 uppercase">Ou</span>
      <hr class="w-full border-slate-800">
    </div>

    <!-- Botão de Login Rápido via Discord (OAuth2) -->
    <a href="/auth/discord" class="mt-4 w-full flex items-center justify-center gap-2 py-2.5 bg-indigo-600 hover:bg-indigo-700 font-bold rounded-lg transition-colors text-white">
      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.873-.894.077.077 0 0 1-.008-.128c.126-.093.252-.19.372-.287a.075.075 0 0 1 .077-.011c3.92 1.793 8.18 1.793 12.061 0a.073.073 0 0 1 .078.009c.12.099.246.195.373.289a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.894.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
      Acessar com o Discord
    </a>
  </div>

  <script>
    // Alterna visualmente os formulários de Login e Cadastro
    function toggleTab(tab) {
      if (tab === 'register') {
        document.getElementById('login-tab').classList.add('push', 'hidden');
        document.getElementById('register-tab').classList.remove('hidden');
      } else {
        document.getElementById('register-tab').classList.add('hidden');
        document.getElementById('login-tab').classList.remove('hidden');
      }
    }
  </script>
</body>
</html>
