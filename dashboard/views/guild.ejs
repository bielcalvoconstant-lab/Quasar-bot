<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Configurações - <%= guild.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen font-sans flex flex-col">

  <!-- Navbar -->
  <nav class="border-b border-slate-800 bg-slate-900/50 backdrop-blur-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <span class="text-xl font-black text-blue-500 tracking-wider">QUASAR - CONFIGURAÇÃO</span>
      <a href="/dashboard" class="text-xs text-slate-400 hover:underline">Voltar ao Painel</a>
    </div>
  </nav>

  <main class="max-w-2xl mx-auto px-4 py-12 flex-grow w-full">
    <div class="flex items-center gap-4 mb-8">
      <% if (guild.icon) { %>
        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" class="w-16 h-16 rounded-full border border-slate-700">
      <% } else { %>
        <div class="w-16 h-16 rounded-full bg-slate-800 flex items-center justify-center font-bold text-slate-300 text-xl"><%= guild.name.charAt(0) %></div>
      <% } %>
      <div>
        <h1 class="text-2xl font-bold"><%= guild.name %></h1>
        <p class="text-xs text-slate-400">ID do Servidor: <%= guild.id %></p>
      </div>
    </div>

    <% if (success) { %>
      <div class="bg-green-500/10 border border-green-500 text-green-400 p-4 rounded-lg text-sm mb-6">
        <%= success %>
      </div>
    <% } %>

    <form action="/dashboard/guild/<%= guild.id %>/update" method="POST" class="bg-slate-900 border border-slate-800 rounded-2xl p-6 space-y-6">
      
      <!-- Canal de Logs -->
      <div>
        <label class="block text-xs font-semibold uppercase text-slate-400 tracking-widest mb-2">Canal de Logs Administrativos</label>
        <select name="logChannelId" class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-slate-100 focus:ring-2 focus:ring-blue-500 outline-none">
          <option value="">Nenhum selecionado</option>
          <% channels.forEach(channel => { %>
            <option value="<%= channel.id %>" <%= config.logChannelId === channel.id ? 'selected' : '' %>># <%= channel.name %></option>
          <% }) %>
        </select>
        <span class="text-xxs text-slate-500 block mt-1">Canal onde serão publicados os relatórios das punições executadas pelo bot.</span>
      </div>

      <!-- Cargo Staff -->
      <div>
        <label class="block text-xs font-semibold uppercase text-slate-400 tracking-widest mb-2">Cargo Permitido para Moderação</label>
        <select name="staffRoleId" class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-slate-100 focus:ring-2 focus:ring-blue-500 outline-none">
          <option value="">Nenhum selecionado</option>
          <% roles.forEach(role => { %>
            <option value="<%= role.id %>" <%= config.staffRoleId === role.id ? 'selected' : '' %>>@ <%= role.name %></option>
          <% }) %>
        </select>
        <span class="text-xxs text-slate-500 block mt-1">Cargo autorizado a interagir com os comandos de banimento e auditoria.</span>
      </div>

      <!-- Limite de Punições -->
      <div>
        <label class="block text-xs font-semibold uppercase text-slate-400 tracking-widest mb-2">Limite Diário de Punições Preventivas</label>
        <input type="number" name="punishmentLimit" min="1" max="100" value="<%= config.punishmentLimit || 5 %>" class="w-full px-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-slate-100 outline-none focus:ring-2 focus:ring-blue-500">
        <span class="text-xxs text-slate-500 block mt-1">Número máximo de expulsões e banimentos que o bot executará por dia para proteger o servidor de abusos.</span>
      </div>

      <button type="submit" class="w-full py-3 bg-blue-600 hover:bg-blue-700 font-bold rounded-lg transition-colors">Salvar Configurações</button>
    </form>
  </main>

  <footer class="border-t border-slate-900 bg-slate-950/60 py-6 text-center text-xs text-slate-500 mt-auto">
    <p>© 2026 Quasar Bot. Todos os direitos reservados.</p>
  </footer>

</body>
</html>
